rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Security Note ──────────────────────────────────────
    // This app uses Clerk for authentication, not Firebase Auth.
    // Firestore security rules cannot validate Clerk tokens directly.
    // In production, implement a backend proxy to verify Clerk tokens.
    // For now, rules allow necessary reads/writes for the app to function.

    // ── Events ────────────────────────────────────────────
    match /events/{eventId} {
      // Public read
      allow read: if true;
      // Allow creation/update/delete for now (secure with backend verification later)
      allow create, update, delete: if true;
    }

    // ── Users ─────────────────────────────────────────────
    match /users/{userId} {
      // Allow authenticated users to read (in production, verify on backend)
      allow read: if true;
      // Allow write for user profile creation/updates
      allow write: if true;
    }

    // ── Enrollments ───────────────────────────────────────
    match /enrollments/{enrollmentId} {
      // Allow reads
      allow read: if true;
      // Allow writes
      allow create, update: if true;
      // Deny delete
      allow delete: if false;
    }

    // ── Rewards ───────────────────────────────────────────
    match /rewards/{rewardId} {
      // Public read only
      allow read: if true;
      // Deny all writes
      allow create, update, delete: if false;
    }

    // ── Organizations ─────────────────────────────────────
    match /organizations/{orgId} {
      // Allow reads
      allow read: if true;
      // Allow writes
      allow create, update: if true;
      // Deny delete
      allow delete: if false;
    }
  }
}
