rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Utility Functions ──────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOrganization() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "organization";
    }

    // ── Events ────────────────────────────────────────────────
    match /events/{eventId} {
      // Public read
      allow read: if true;
      // Only authenticated org users can create
      allow create: if isAuthenticated() && isOrganization();
      // Only org that created event can edit/delete
      allow update, delete: if isAuthenticated() && resource.data.organizationId == request.auth.uid;
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      // Users can create their own profile during onboarding
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Users can only update their own profile
      allow update: if isAuthenticated() && request.auth.uid == userId;
      // Deny delete
      allow delete: if false;
    }

    // ── Enrollments ───────────────────────────────────────────
    match /enrollments/{enrollmentId} {
      let eventDoc = get(/databases/$(database)/documents/events/$(request.resource.data.eventId));

      // Authenticated users can read their own enrollments
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      // Orgs can read enrollments for their events
      allow read: if isAuthenticated() && isOrganization() &&
                      get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId == request.auth.uid;

      // Authenticated users can enroll themselves
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;

      // Org can update attendance for their events, users can't update
      allow update: if isAuthenticated() && isOrganization() &&
                       get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizationId == request.auth.uid;

      // Deny delete
      allow delete: if false;
    }

    // ── Rewards ───────────────────────────────────────────────
    match /rewards/{rewardId} {
      // Public read only
      allow read: if true;
      // Deny all writes
      allow create, update, delete: if false;
    }

    // ── Organizations ─────────────────────────────────────────
    match /organizations/{orgId} {
      // Authenticated users can read org profiles
      allow read: if isAuthenticated();
      // Orgs can create their own profile
      allow create: if isAuthenticated() && request.auth.uid == orgId;
      // Orgs can update their own profile
      allow update: if isAuthenticated() && request.auth.uid == orgId;
      // Deny delete
      allow delete: if false;
    }
  }
}
